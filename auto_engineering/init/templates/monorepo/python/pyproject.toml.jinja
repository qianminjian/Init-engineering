# {{ repo_name }} — uv workspace root
#
# 统一所有 workspace members 的依赖图。子包仅声明本包依赖，
# workspace 级依赖写在这里。
#
# Why uv workspaces: 跨包改动是原子事务（uv lock 同步所有 member），
# 优于传统的 setuptools / pip editable install 模式。

[project]
name = "{{ repo_name }}"
version = "0.1.0"
description = "{{ repo_description }}"
requires-python = ">=3.12"
dependencies = []

[project.optional-dependencies]
dev = [
    "pytest>=8",
    "pytest-cov>=5",
    "ruff>=0.8",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.uv.workspace]
members = [
    "packages/*",
    "apps/*",
    "tools/*",
]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]

[tool.pytest.ini_options]
testpaths = ["packages", "apps", "tools"]
addopts = ["--timeout=60", "-p no:cacheprovider"]

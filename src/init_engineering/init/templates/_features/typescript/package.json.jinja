{
  "name": "{{ project_name }}",
  "version": "0.1.0",
  "description": "{{ project_description }}",
  "type": "module",
{% if project_type == 'app-service' %}
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "{{ test_runner }}",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "vite": "^6",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "@eslint/js": "^9",
    "typescript-eslint": "^8",
    "prettier": "^3"{% if test_runner == 'vitest' %},
    "vitest": "^3"{% endif %}{% if test_runner == 'jest' %},
    "jest": "^30",
    "@types/jest": "^30",
    "ts-jest": "^30"{% endif %}
  }
{% else %}
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "{{ test_runner }}",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "typescript": "^5.7",
    "@types/node": "^22",
    "eslint": "^9",
    "@eslint/js": "^9",
    "typescript-eslint": "^8",
    "prettier": "^3"{% if test_runner == 'vitest' %},
    "vitest": "^3"{% endif %}{% if test_runner == 'jest' %},
    "jest": "^30",
    "@types/jest": "^30",
    "ts-jest": "^30"{% endif %}
  }
{% endif %}
}

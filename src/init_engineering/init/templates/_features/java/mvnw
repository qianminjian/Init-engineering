#!/bin/sh
# Maven Wrapper startup script
# ----------------------------------------------------------------------------

# Resolve links - $0 may be a softlink
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done

PRG_DIR=$(dirname "$PRG")
MAVEN_PROJECTBASEDIR=$(cd "$PRG_DIR/.." > /dev/null 2>&1 && pwd)

if [ -z "$MAVEN_HOME" ]; then
  MAVEN_HOME="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-home"
fi

# Find Java
if [ -n "$JAVA_HOME" ]; then
  JAVA_EXEC="$JAVA_HOME/bin/java"
else
  JAVA_EXEC="java"
fi

MAVEN_OPTS="${MAVEN_OPTS:-} -Xmx1024m -XX:MaxMetaspaceSize=256m"

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Download maven-wrapper.jar if not present
if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Downloading Maven Wrapper..."
  WRAPPER_URL=$(grep 'wrapperUrl=' "$WRAPPER_PROPERTIES" | cut -d= -f2-)
  if command -v curl > /dev/null 2>&1; then
    curl -fsSLo "$WRAPPER_JAR" "$WRAPPER_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "ERROR: Neither curl nor wget found. Please install one or download maven-wrapper.jar manually."
    exit 1
  fi
fi

# Download Maven distribution if not present
DIST_URL=$(grep 'distributionUrl=' "$WRAPPER_PROPERTIES" | cut -d= -f2-)
DIST_DIR="$MAVEN_HOME"
if [ ! -d "$DIST_DIR" ]; then
  echo "Downloading Maven distribution..."
  mkdir -p "$DIST_DIR"
  TMP_ZIP="$DIST_DIR/maven.zip"
  if command -v curl > /dev/null 2>&1; then
    curl -fsSLo "$TMP_ZIP" "$DIST_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMP_ZIP" "$DIST_URL"
  fi
  unzip -qo "$TMP_ZIP" -d "$DIST_DIR" 2>/dev/null
  rm -f "$TMP_ZIP"
  # Maven distribution unzips to apache-maven-X.Y.Z/ inside DIST_DIR
  MVN_HOME=$(find "$DIST_DIR" -maxdepth 2 -name "bin" -type d 2>/dev/null | head -1 | xargs dirname 2>/dev/null)
fi

# Use system mvn if available, otherwise use wrapper-downloaded
if command -v mvn > /dev/null 2>&1; then
  MVN_CMD="mvn"
elif [ -n "${MVN_HOME:-}" ] && [ -d "$MVN_HOME/bin" ]; then
  MVN_CMD="$MVN_HOME/bin/mvn"
else
  echo "ERROR: Maven not found. Install Maven or ensure maven-wrapper.properties is correct."
  exit 1
fi

exec "$JAVA_EXEC" \
  $MAVEN_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  ${WRAPPER_LAUNCHER:-org.apache.maven.wrapper.MavenWrapperMain} \
  "$@"

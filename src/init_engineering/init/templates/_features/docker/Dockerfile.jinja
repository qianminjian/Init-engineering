{%- if language == 'typescript' %}
FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json {{ package_manager }}-lock.yaml* ./
RUN {{ package_manager }} install --frozen-lockfile
COPY . .
RUN {{ package_manager }} run build

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
EXPOSE 3000
CMD ["node", "dist/index.js"]
{%- elif language == 'python' %}
FROM python:3.12-slim
WORKDIR /app
COPY pyproject.toml ./
RUN pip install --no-cache-dir .
COPY . .
EXPOSE 8000
CMD ["python", "-m", "{{ project_name }}"]
{%- elif language == 'go' %}
FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /app/bin/{{ project_name }} .

FROM alpine:latest
WORKDIR /app
COPY --from=builder /app/bin/{{ project_name }} .
EXPOSE 8080
CMD ["./{{ project_name }}"]
{%- elif language == 'rust' %}
FROM rust:latest AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
RUN cargo build --release
COPY . .
RUN cargo build --release

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=builder /app/target/release/{{ project_name }} .
EXPOSE 8080
CMD ["./{{ project_name }}"]
{%- endif %}

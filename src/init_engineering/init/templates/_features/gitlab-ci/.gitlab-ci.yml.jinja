stages:
  - test
  - lint
{% if language == 'typescript' or language == 'javascript' %}
test:
  image: node:22-alpine
  stage: test
  before_script:
    - corepack enable && corepack prepare pnpm@latest --activate
    - pnpm install --frozen-lockfile
  script:
    - pnpm run test
  cache:
    key: {% raw %}${CI_COMMIT_REF_SLUG}{% endraw %}
    paths:
      - node_modules/
lint:
  image: node:22-alpine
  stage: lint
  before_script:
    - corepack enable && corepack prepare pnpm@latest --activate
    - pnpm install --frozen-lockfile
  script:
    - pnpm run lint
  cache:
    key: {% raw %}${CI_COMMIT_REF_SLUG}{% endraw %}
    paths:
      - node_modules/
{% elif language == 'python' %}
test:
  image: python:3.13-alpine
  stage: test
  before_script:
    - pip install uv && uv sync
  script:
    - uv run pytest
lint:
  image: python:3.13-alpine
  stage: lint
  before_script:
    - pip install uv && uv sync
  script:
    - uv run ruff check .
{% elif language == 'go' %}
test:
  image: golang:1.22-alpine
  stage: test
  script:
    - go test ./...
lint:
  image: golang:1.22-alpine
  stage: lint
  script:
    - go vet ./...
{% elif language == 'rust' %}
test:
  image: rust:1.80-alpine
  stage: test
  script:
    - cargo test
lint:
  image: rust:1.80-alpine
  stage: lint
  before_script:
    - rustup component add clippy rustfmt
  script:
    - cargo fmt --check
    - cargo clippy -- -D warnings
{% elif language == 'java' %}
test:
  image: maven:3-eclipse-temurin-{{ java_version | default(detected_java_version) }}
  stage: test
  script:
    - mvn {% if aggregator_path is defined and aggregator_path %}-f {{ aggregator_path }}/pom.xml {% endif %}test --batch-mode
{%- if java_extra_modules is defined and java_extra_modules %}
{%- for m in java_extra_modules.split(",") | map("trim") | list %}
    - mvn -f {{ m }}/pom.xml test --batch-mode
{%- endfor %}
{%- endif %}
lint:
  image: maven:3-eclipse-temurin-{{ java_version | default(detected_java_version) }}
  stage: lint
  script:
    - mvn {% if aggregator_path is defined and aggregator_path %}-f {{ aggregator_path }}/pom.xml {% endif %}checkstyle:check --batch-mode
{%- if java_extra_modules is defined and java_extra_modules %}
{%- for m in java_extra_modules.split(",") | map("trim") | list %}
    - mvn -f {{ m }}/pom.xml checkstyle:check --batch-mode
{%- endfor %}
{%- endif %}
{% endif %}
